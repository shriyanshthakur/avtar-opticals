---
---
<footer class="bg-brand-dark text-brand-light border-t border-brand-gold/15 py-12 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      
      <!-- Column 1: Brand details -->
      <div class="space-y-4 text-left">
        <a href="#" class="flex items-center gap-3 group">
          <div class="w-8 h-8 rounded-full bg-brand-light flex items-center justify-center border border-brand-gold/30">
            <span class="font-display font-bold text-sm text-brand-dark">A</span>
          </div>
          <span class="font-display font-bold text-base tracking-wide text-brand-light uppercase">Avtar Opticals</span>
        </a>
        <p class="text-[11px] sm:text-xs text-brand-light/60 leading-relaxed max-w-xs">
          Your trusted optical wholesaler & retail showroom in Sector 6, Bhilai. Offering a wide range of wholesale frames, prescription spectacles, and brand contact lenses like Bausch + Lomb.
        </p>
        <div class="flex items-center gap-4 pt-2">
          <a href="https://www.facebook.com/avtaroptical/" target="_blank" rel="noopener noreferrer" class="text-brand-light/60 hover:text-brand-gold transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M9 8H7v3h2v9h3v-9h2.72l.42-3H12V6c0-.9.27-1.5 1.5-1.5H15V2.05c-.3-.04-1.3-.13-2.5-.13C10 1.92 8 3.32 8 6.5V8h1z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/avtar_optical/" target="_blank" rel="noopener noreferrer" class="text-brand-light/60 hover:text-brand-gold transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="space-y-4 text-left">
        <h4 class="font-accent font-bold text-xs uppercase tracking-wider text-brand-gold">Quick Links</h4>
        <nav class="flex flex-col space-y-2 text-xs text-brand-light/75">
          <a href="#" class="hover:text-brand-gold transition-colors">Home</a>
          <a href="#services" class="hover:text-brand-gold transition-colors">Services</a>
          <a href="#wholesale-inquiries" class="hover:text-brand-gold transition-colors">Wholesale Inquiries</a>
          <a href="#location" class="hover:text-brand-gold transition-colors">Location & Hours</a>
        </nav>
      </div>

      <!-- Column 3: Products -->
      <div class="space-y-4 text-left">
        <h4 class="font-accent font-bold text-xs uppercase tracking-wider text-brand-gold">Products</h4>
        <nav class="flex flex-col space-y-2 text-xs text-brand-light/75">
          <span class="hover:text-brand-gold cursor-default transition-colors">Wholesale Frames Catalog</span>
          <span class="hover:text-brand-gold cursor-default transition-colors">Retail Eyeglasses</span>
          <span class="hover:text-brand-gold cursor-default transition-colors">Contact Lenses (Bausch + Lomb)</span>
          <span class="hover:text-brand-gold cursor-default transition-colors">Stylish Sunglasses</span>
          <span class="hover:text-brand-gold cursor-default transition-colors">Full-Coverage Frames</span>
        </nav>
      </div>

      <!-- Column 4: Contact info -->
      <div class="space-y-4 text-left">
        <h4 class="font-accent font-bold text-xs uppercase tracking-wider text-brand-gold">Contact Info</h4>
        <div class="text-xs text-brand-light/75 space-y-2">
          <div>
            <span class="font-bold text-brand-gold">Phone:</span> <br />
            <a href="tel:07987170637" class="hover:text-brand-gold transition-colors">079871 70637</a>
          </div>
          <div>
            <span class="font-bold text-brand-gold">Showroom Address:</span> <br />
            A Market, Block 6, State Bank Colony, Sector 6, Bhilai, Chhattisgarh 490006
          </div>
          <div>
            <span class="font-bold text-brand-gold">Business Type:</span> <br />
            Optical Wholesaler & Retail Shop
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom border & copyright -->
    <div class="border-t border-brand-light/10 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-[10px] sm:text-xs text-brand-light/50">
      <div>
        &copy; {new Date().getFullYear()} Avtar Opticals. All Rights Reserved.
      </div>
      <div>
        Bhilai's Trusted Wholesaler & Retailer.
      </div>
    </div>
  </div>
</footer>
