---
---
<section id="categories" class="py-20 bg-brand-cream relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
      <div class="space-y-4 text-left">
        <div class="text-[10px] sm:text-xs font-accent font-bold tracking-widest text-brand-gold-dark uppercase">Explore Products</div>
        <h2 class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-brand-dark">
          Our Products & <span class="font-normal italic text-brand-gold-dark">Services</span>
        </h2>
      </div>
      <p class="font-sans text-brand-dark/70 text-sm max-w-md md:text-right leading-relaxed">
        From bulk frame supply to customized prescription glasses and branded lenses, discover what we do.
      </p>
    </div>

    <!-- Category Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Category 1: Wholesale Frames -->
      <div class="group relative aspect-[3/4] rounded-3xl overflow-hidden border border-brand-gold/15 shadow-lg bg-brand-dark">
        <img 
          src="https://images.unsplash.com/photo-1591076482161-42ce6da69f67?q=80&w=800&auto=format&fit=crop" 
          alt="Wholesale Eyewear Frames Display" 
          class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105 opacity-90 group-hover:opacity-75"
          loading="lazy"
        />
        <!-- Vignette and color overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"></div>
        
        <!-- Content -->
        <div class="absolute inset-0 p-8 flex flex-col justify-end text-left space-y-3">
          <div class="text-[10px] font-accent font-bold tracking-widest text-brand-gold uppercase">Bulk Distribution</div>
          <h3 class="font-display text-2xl font-bold text-brand-light">Wholesale Frames</h3>
          <p class="text-xs text-brand-light/70 leading-relaxed max-w-xs transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            A comprehensive catalog of high-quality bulk optical frames at primary distributor pricing for retail businesses.
          </p>
          <div class="pt-2">
            <a 
              href="#wholesale-inquiries" 
              class="inline-flex items-center gap-2 text-xs font-accent font-bold text-brand-gold hover:text-brand-gold-light transition-colors"
            >
              <span>Get Wholesale Price List</span>
              <span>→</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Category 2: Retail Eyewear -->
      <div class="group relative aspect-[3/4] rounded-3xl overflow-hidden border border-brand-gold/15 shadow-lg bg-brand-dark">
        <img 
          src="https://images.unsplash.com/photo-1511556532299-8f662fc26c06?q=80&w=800&auto=format&fit=crop" 
          alt="Retail Eyewear Fitting" 
          class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105 opacity-90 group-hover:opacity-75"
          loading="lazy"
        />
        <!-- Vignette and color overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"></div>
        
        <!-- Content -->
        <div class="absolute inset-0 p-8 flex flex-col justify-end text-left space-y-3">
          <div class="text-[10px] font-accent font-bold tracking-widest text-brand-gold uppercase">Stylish & Practical</div>
          <h3 class="font-display text-2xl font-bold text-brand-light">Retail Eyewear</h3>
          <p class="text-xs text-brand-light/70 leading-relaxed max-w-xs transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            Find stylish yet practical frames providing full eye coverage. Perfectly customized prescription fitting in store.
          </p>
          <div class="pt-2">
            <a 
              href="tel:07987170637" 
              class="inline-flex items-center gap-2 text-xs font-accent font-bold text-brand-gold hover:text-brand-gold-light transition-colors"
            >
              <span>Call For Catalog</span>
              <span>→</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Category 3: Contact Lenses -->
      <div class="group relative aspect-[3/4] rounded-3xl overflow-hidden border border-brand-gold/15 shadow-lg bg-brand-dark">
        <img 
          src="https://images.unsplash.com/photo-1508962914676-134849a727f0?q=80&w=800&auto=format&fit=crop" 
          alt="Branded Contact Lenses" 
          class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105 opacity-90 group-hover:opacity-75"
          loading="lazy"
        />
        <!-- Vignette and color overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"></div>
        
        <!-- Content -->
        <div class="absolute inset-0 p-8 flex flex-col justify-end text-left space-y-3">
          <div class="text-[10px] font-accent font-bold tracking-widest text-brand-gold uppercase">Bausch + Lomb & More</div>
          <h3 class="font-display text-2xl font-bold text-brand-light">Contact Lenses</h3>
          <p class="text-xs text-brand-light/70 leading-relaxed max-w-xs transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            High oxygen permeability daily, monthly, and toric contact lenses. Prominently stocking brands like Bausch + Lomb.
          </p>
          <div class="pt-2">
            <a 
              href="tel:07987170637" 
              class="inline-flex items-center gap-2 text-xs font-accent font-bold text-brand-gold hover:text-brand-gold-light transition-colors"
            >
              <span>Order Contact Lenses</span>
              <span>→</span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
