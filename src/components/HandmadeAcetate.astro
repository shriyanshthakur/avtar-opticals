---
---
<section id="craftsmanship" class="py-20 bg-brand-light relative overflow-hidden">
  <!-- Dynamic subtle geometric lines -->
  <div class="absolute inset-0 z-0 opacity-10">
    <div class="absolute top-1/2 left-0 right-0 h-[1px] bg-brand-gold"></div>
    <div class="absolute top-0 bottom-0 left-1/4 w-[1px] bg-brand-gold"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <!-- Visual Showcase (Left on Desktop) -->
      <div class="lg:col-span-6 relative order-last lg:order-first">
        <!-- Frame background box -->
        <div class="absolute -inset-4 bg-brand-cream border border-brand-gold/10 rounded-[2.5rem] -rotate-2"></div>
        
        <div class="relative aspect-[4/3] sm:aspect-[16/10] lg:aspect-[4/3] rounded-[2rem] overflow-hidden border border-brand-gold/25 shadow-xl">
          <img 
            src="https://images.unsplash.com/photo-1508296695146-257a814070b4?q=80&w=800&auto=format&fit=crop" 
            alt="Close-up details of modern eyewear frames" 
            class="w-full h-full object-cover object-center transition-transform duration-700 hover:scale-105"
            loading="lazy"
          />
        </div>
        
        <!-- Overlapping Material Spec Card -->
        <div class="absolute -bottom-6 right-6 bg-brand-dark text-brand-light p-6 rounded-2xl border border-brand-gold/20 shadow-2xl max-w-[240px]">
          <div class="font-display font-medium text-lg text-brand-gold">Optimal Coverage</div>
          <p class="text-[10px] sm:text-xs text-brand-light/70 leading-relaxed mt-2">
            Engineered to rest comfortably while maximizing eye protection from dust, wind, and ambient UV glare.
          </p>
        </div>
      </div>

      <!-- Narrative Showcase (Right on Desktop) -->
      <div class="lg:col-span-6 space-y-8 text-left">
        <div class="space-y-4">
          <div class="text-[10px] sm:text-xs font-accent font-bold tracking-widest text-brand-gold-dark uppercase">Our Design Philosophy</div>
          <h2 class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-brand-dark leading-tight">
            Stylish Yet Practical <br />
            <span class="font-normal italic text-brand-gold-dark">Full Eye Coverage</span>
          </h2>
          <p class="font-sans text-brand-dark/70 text-sm sm:text-base leading-relaxed">
            At Avtar Opticals, we believe that eyewear should be an extension of your personal style without compromising on comfort and health. Our curated frame collections focus on wide-profile designs that provide complete eye coverage, shielding your eyes from environmental elements like dust and glare.
          </p>
        </div>

        <!-- Detail points with icons -->
        <div class="space-y-6">
          
          <!-- Detail 1 -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-gold/10 flex items-center justify-center text-brand-gold-dark font-bold text-xs">
              01
            </div>
            <div>
              <h4 class="font-display font-bold text-sm text-brand-dark">Full Environmental Protection</h4>
              <p class="text-xs text-brand-dark/70 leading-relaxed mt-1">
                Wider lens contours designed to block lateral wind, road dust, and ambient sun glare—highly practical for local travel.
              </p>
            </div>
          </div>

          <!-- Detail 2 -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-gold/10 flex items-center justify-center text-brand-gold-dark font-bold text-xs">
              02
            </div>
            <div>
              <h4 class="font-display font-bold text-sm text-brand-dark">Lightweight & Ergonomic</h4>
              <p class="text-xs text-brand-dark/70 leading-relaxed mt-1">
                Carefully selected materials that maintain excellent structural durability without adding weight, avoiding nose fatigue.
              </p>
            </div>
          </div>

          <!-- Detail 3 -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-gold/10 flex items-center justify-center text-brand-gold-dark font-bold text-xs">
              03
            </div>
            <div>
              <h4 class="font-display font-bold text-sm text-brand-dark">Diverse & Trendy Catalog</h4>
              <p class="text-xs text-brand-dark/70 leading-relaxed mt-1">
                Available in multiple colorways, structures, and sizing options, accommodating both bulk optical stores and retail shoppers.
              </p>
            </div>
          </div>

        </div>

        <div class="pt-4">
          <a 
            href="tel:07987170637" 
            class="inline-flex items-center gap-3 px-6 py-3 bg-brand-cream hover:bg-brand-sand border border-brand-gold/45 text-brand-dark font-accent font-bold tracking-wider text-xs uppercase rounded-full transition-all duration-300 shadow-sm"
          >
            <span>Call For Frame Availability</span>
            <span>→</span>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
