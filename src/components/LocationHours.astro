---
---
<section id="location" class="py-20 bg-brand-light relative">
  <!-- Anchor for Wholesale Inquiries -->
  <div id="wholesale-inquiries" class="absolute -top-20"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      
      <!-- Contact & Hours Details (Left Column) -->
      <div class="lg:col-span-5 space-y-10 text-left">
        
        <!-- Section Header -->
        <div class="space-y-4">
          <div class="text-[10px] sm:text-xs font-accent font-bold tracking-widest text-brand-gold-dark uppercase">Location & Hours</div>
          <h2 class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-brand-dark">
            Visit Our Showroom in <br />
            <span class="font-normal italic text-brand-gold-dark">Bhilai, Chhattisgarh</span>
          </h2>
          <p class="font-sans text-brand-dark/70 text-sm sm:text-base leading-relaxed">
            Drop by our showroom in Sector 6 for custom fittings, retail eyewear, or direct wholesale catalog and pricing consultations.
          </p>
        </div>

        <!-- Addresses & Contacts Info -->
        <div class="space-y-6">
          
          <!-- Primary Location -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center text-brand-gold-dark">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div class="space-y-1">
              <h3 class="font-display font-bold text-sm text-brand-dark uppercase tracking-wider">Showroom Address</h3>
              <p class="text-xs text-brand-dark/75 leading-relaxed">
                A Market, Block 6, State Bank Colony, Sector 6, Bhilai, Chhattisgarh 490006
              </p>
              <div class="pt-1">
                <a 
                  href="tel:07987170637" 
                  class="font-accent font-bold text-xs text-brand-gold-dark hover:text-brand-gold hover:underline"
                >
                  Phone: 079871 70637
                </a>
              </div>
            </div>
          </div>

          <!-- Store Hours -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center text-brand-gold-dark">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="space-y-1 w-full">
              <h3 class="font-display font-bold text-sm text-brand-dark uppercase tracking-wider">Store Hours</h3>
              <div class="text-xs text-brand-dark/75 space-y-1">
                <div><span class="font-semibold text-brand-dark">Monday–Saturday:</span> 10:30 AM to 9:30 PM</div>
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-semibold text-brand-dark">Sunday:</span> 
                  <span>Closes early at 9:30 AM</span>
                  <span class="bg-amber-100 text-amber-800 text-[9px] font-bold px-1.5 py-0.5 rounded border border-amber-200">Early Close</span>
                </div>
              </div>
              
              <!-- Call for Store Hours CTA Prompt -->
              <div class="mt-3 p-3 bg-brand-gold/10 border border-brand-gold/20 rounded-xl flex flex-col sm:flex-row sm:items-center justify-between gap-3 max-w-sm">
                <span class="text-[10px] text-brand-dark/80 font-medium">Hours may vary. Confirm before visiting:</span>
                <a 
                  href="tel:07987170637" 
                  class="w-fit text-center px-3 py-1 bg-brand-dark hover:bg-brand-dark-card text-brand-light text-[10px] font-accent font-bold uppercase rounded-md transition-all duration-200"
                >
                  Call for Hours
                </a>
              </div>
            </div>
          </div>

        </div>

        <!-- Google Maps Iframe -->
        <div class="relative w-full aspect-[16/10] sm:aspect-[16/9] lg:aspect-[16/10] rounded-2xl overflow-hidden border border-brand-gold/25 shadow-md">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14874.3995874288!2d81.3361845!3d21.1980838!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a28dd387431e505%3A0xc3cf0fcd7f516a8d!2sSector%206%2C%20Bhilai%2C%20Chhattisgarh%20490006!5e0!3m2!1sen!2sin!4v1718715000000!5m2!1sen!2sin" 
            class="absolute inset-0 w-full h-full border-0" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Google Map location of Avtar Opticals in Sector 6, Bhilai"
          ></iframe>
        </div>

      </div>

      <!-- Wholesale & General Inquiry Form (Right Column) -->
      <div class="lg:col-span-7 bg-brand-cream border border-brand-gold/15 p-8 rounded-3xl shadow-xl text-left">
        <h3 class="font-display font-medium text-2xl text-brand-dark mb-2 font-accent">Wholesale & Retail Inquiry</h3>
        <p class="text-xs text-brand-dark/70 mb-6 leading-relaxed">
          Are you a retail shop looking for bulk frames and lenses, or a local customer interested in style consulting and custom frames? Submit your details below, and we will contact you immediately.
        </p>

        <form id="appointment-form" class="space-y-5">
          <!-- Form notification -->
          <div id="form-success" class="hidden p-4 bg-emerald-50 border border-emerald-300 rounded-xl text-emerald-800 text-xs font-semibold">
            Thank you! Your inquiry has been submitted. Avtar Opticals will contact you shortly to assist.
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Full Name / Business Name -->
            <div class="space-y-1.5">
              <label for="name" class="block text-[10px] font-accent font-bold tracking-wider text-brand-dark/80 uppercase">Your Name / Business Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                placeholder="e.g. Anand Opticals or Rajesh Kumar"
                class="w-full bg-brand-light border border-brand-gold/30 rounded-xl px-4 py-3 text-xs text-brand-dark placeholder-brand-dark/40 focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
            <!-- Phone Number -->
            <div class="space-y-1.5">
              <label for="phone" class="block text-[10px] font-accent font-bold tracking-wider text-brand-dark/80 uppercase">Phone Number</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                required 
                placeholder="e.g. 098765 43210"
                class="w-full bg-brand-light border border-brand-gold/30 rounded-xl px-4 py-3 text-xs text-brand-dark placeholder-brand-dark/40 focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Inquiry Category -->
            <div class="space-y-1.5">
              <label for="interest" class="block text-[10px] font-accent font-bold tracking-wider text-brand-dark/80 uppercase">What are you looking for?</label>
              <select 
                id="interest" 
                name="interest"
                class="w-full bg-brand-light border border-brand-gold/30 rounded-xl px-4 py-3 text-xs text-brand-dark focus:outline-none focus:border-brand-gold transition-colors duration-200"
              >
                <option value="wholesale-frames">Wholesale Frames Catalog</option>
                <option value="wholesale-contacts">Bulk Contact Lenses (Bausch + Lomb)</option>
                <option value="retail-fitting">Retail Eyewear & Custom Lenses</option>
                <option value="other">General Inquiry</option>
              </select>
            </div>
            <!-- Quantity / Urgency -->
            <div class="space-y-1.5">
              <label for="urgency" class="block text-[10px] font-accent font-bold tracking-wider text-brand-dark/80 uppercase">Estimated Requirement Size</label>
              <select 
                id="urgency" 
                name="urgency"
                class="w-full bg-brand-light border border-brand-gold/30 rounded-xl px-4 py-3 text-xs text-brand-dark focus:outline-none focus:border-brand-gold transition-colors duration-200"
              >
                <option value="bulk-large">Bulk wholesale (50+ frames)</option>
                <option value="bulk-medium">Bulk wholesale (10-50 frames)</option>
                <option value="single-retail">Single pair (Personal retail)</option>
                <option value="other">Just inquiring</option>
              </select>
            </div>
          </div>

          <!-- Message -->
          <div class="space-y-1.5">
            <label for="message" class="block text-[10px] font-accent font-bold tracking-wider text-brand-dark/80 uppercase">Inquiry details / Message (Optional)</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              placeholder="Tell us about specific frame designs, lens brands like Bausch + Lomb, quantities, or styles you require..."
              class="w-full bg-brand-light border border-brand-gold/30 rounded-xl px-4 py-3 text-xs text-brand-dark placeholder-brand-dark/40 focus:outline-none focus:border-brand-gold transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full py-4 bg-brand-dark hover:bg-brand-dark-card text-brand-light font-accent font-bold tracking-wider text-xs uppercase rounded-xl border border-brand-dark transition-all duration-300 shadow-md hover:scale-[1.01] cursor-pointer"
          >
            Submit Inquiry
          </button>
        </form>
      </div>

    </div>

  </div>
</section>

<script>
  const form = document.getElementById('appointment-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');

  if (form && successMsg) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const name = formData.get('name');
      const phone = formData.get('phone');
      
      if (!name || !phone) return;

      successMsg.classList.remove('hidden');
      form.reset();

      successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

      setTimeout(() => {
        successMsg.classList.add('hidden');
      }, 5000);
    });
  }
</script>
