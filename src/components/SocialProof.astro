---
---
<section id="reviews" class="py-20 bg-brand-cream relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      
      <!-- Left: Google Reviews Summary & Highlights -->
      <div class="lg:col-span-5 space-y-8 text-left">
        <div class="space-y-4">
          <div class="text-[10px] sm:text-xs font-accent font-bold tracking-widest text-brand-gold-dark uppercase">Trusted in Bhilai</div>
          <h2 class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-brand-dark">
            What Our Customers <br />
            <span class="font-normal italic text-brand-gold-dark">Say About Us</span>
          </h2>
          <p class="font-sans text-brand-dark/70 text-sm sm:text-base leading-relaxed">
            From recommending the perfect frames to supplying bulk orders, we are dedicated to providing friendly service and premium quality optical care in Sector 6.
          </p>
        </div>

        <!-- Rating Overview Card -->
        <div class="glass-card p-6 rounded-2xl border border-brand-gold/20 shadow-md flex items-center gap-6">
          <div class="text-center bg-brand-dark text-brand-light p-4 rounded-xl">
            <div class="text-3xl font-display font-bold text-brand-gold">3.8</div>
            <div class="text-[10px] font-accent font-bold text-brand-light/60 uppercase mt-1">Google Rating</div>
          </div>
          <div class="space-y-1">
            <div class="flex text-amber-500 text-lg">
              <span>★</span><span>★</span><span>★</span><span>★</span><span class="text-brand-gray-light">★</span>
            </div>
            <div class="text-xs font-bold text-brand-dark">Based on 10 Google Reviews</div>
            <p class="text-[10px] sm:text-xs text-brand-dark/60">
              Highly rated for friendly staff and ownership, and stylish, practical design selections.
            </p>
          </div>
        </div>

        <!-- Google Reviews Mockups -->
        <div class="space-y-4">
          
          <!-- Review 1 -->
          <div class="bg-brand-light/75 border border-brand-gold/10 p-5 rounded-xl space-y-2">
            <div class="flex justify-between items-center">
              <div class="font-accent font-bold text-xs text-brand-dark">Google Reviewer</div>
              <div class="text-amber-500 text-xs">★★★★★</div>
            </div>
            <p class="text-xs text-brand-dark/70 leading-relaxed italic">
              "Nice shop, friendly staff and owner ...sardarji 😎"
            </p>
          </div>

          <!-- Review 2 -->
          <div class="bg-brand-light/75 border border-brand-gold/10 p-5 rounded-xl space-y-2">
            <div class="flex justify-between items-center">
              <div class="font-accent font-bold text-xs text-brand-dark">Local Guide</div>
              <div class="text-amber-500 text-xs">★★★★★</div>
            </div>
            <p class="text-xs text-brand-dark/70 leading-relaxed italic">
              "The design is stylish yet practical, and they give full coverage for the eyes."
            </p>
          </div>

          <!-- Review 3 -->
          <div class="bg-brand-light/75 border border-brand-gold/10 p-5 rounded-xl space-y-2">
            <div class="flex justify-between items-center">
              <div class="font-accent font-bold text-xs text-brand-dark">R. Singh</div>
              <div class="text-amber-500 text-xs">★★★★★</div>
            </div>
            <p class="text-xs text-brand-dark/70 leading-relaxed italic">
              "Wide selection of wholesale frames and contact lenses. The owner is very accommodating and rates are very reasonable."
            </p>
          </div>

        </div>
      </div>

      <!-- Right: Gallery / Showroom Highlights -->
      <div class="lg:col-span-7 space-y-8">
        
        <!-- Header for Showroom Section -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-brand-gold/15 pb-6">
          <div class="text-left">
            <div class="text-[10px] sm:text-xs font-accent font-bold tracking-widest text-brand-gold-dark uppercase">Browse Showroom</div>
            <h3 class="font-display font-medium text-2xl text-brand-dark mt-1">In-Store Highlights</h3>
          </div>
          
          <!-- Call Badge -->
          <a 
            href="tel:07987170637" 
            class="flex items-center gap-3 bg-brand-light/80 hover:bg-brand-light border border-brand-gold/30 px-4 py-2.5 rounded-full shadow-sm w-fit transition-colors duration-200 group"
          >
            <div class="w-7 h-7 rounded-full bg-brand-dark flex items-center justify-center text-brand-gold text-xs font-bold font-display shadow-sm">
              📞
            </div>
            <div class="text-left">
              <div class="text-xs font-bold text-brand-dark group-hover:text-brand-gold-dark transition-colors font-accent">079871 70637</div>
              <div class="text-[9px] font-accent font-bold text-brand-gold-dark uppercase tracking-wider">Wholesale & Retail</div>
            </div>
          </a>
        </div>

        <!-- Showcase Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          
          <!-- Item 1 -->
          <div class="group relative aspect-square rounded-2xl overflow-hidden bg-brand-dark border border-brand-gold/10">
            <img 
              src="https://images.unsplash.com/photo-1591076482161-42ce6da69f67?q=80&w=400&auto=format&fit=crop" 
              alt="Stylish spectacles selection" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-90 group-hover:opacity-75"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-brand-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4">
              <span class="text-brand-light font-accent font-bold text-[10px] tracking-wider uppercase border border-brand-light/45 px-3 py-1.5 rounded-full">Retail Eyewear</span>
            </div>
          </div>

          <!-- Item 2 -->
          <div class="group relative aspect-square rounded-2xl overflow-hidden bg-brand-dark border border-brand-gold/10">
            <img 
              src="https://images.unsplash.com/photo-1574258495973-f010dfbb5371?q=80&w=400&auto=format&fit=crop" 
              alt="Model wearing modern frames" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-90 group-hover:opacity-75"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-brand-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4">
              <span class="text-brand-light font-accent font-bold text-[10px] tracking-wider uppercase border border-brand-light/45 px-3 py-1.5 rounded-full">Stylish Frames</span>
            </div>
          </div>

          <!-- Item 3 -->
          <div class="group relative aspect-square rounded-2xl overflow-hidden bg-brand-dark border border-brand-gold/10">
            <img 
              src="https://images.unsplash.com/photo-1508296695146-257a814070b4?q=80&w=400&auto=format&fit=crop" 
              alt="Eyewear frame detail" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-90 group-hover:opacity-75"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-brand-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4">
              <span class="text-brand-light font-accent font-bold text-[10px] tracking-wider uppercase border border-brand-light/45 px-3 py-1.5 rounded-full">Detailed Craft</span>
            </div>
          </div>

          <!-- Item 4 -->
          <div class="group relative aspect-square rounded-2xl overflow-hidden bg-brand-dark border border-brand-gold/10">
            <img 
              src="https://images.unsplash.com/photo-1511499767150-a48a237f0083?q=80&w=400&auto=format&fit=crop" 
              alt="Practical frames on display" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-90 group-hover:opacity-75"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-brand-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4">
              <span class="text-brand-light font-accent font-bold text-[10px] tracking-wider uppercase border border-brand-light/45 px-3 py-1.5 rounded-full">Practical Protection</span>
            </div>
          </div>

          <!-- Item 5 -->
          <div class="group relative aspect-square rounded-2xl overflow-hidden bg-brand-dark border border-brand-gold/10">
            <img 
              src="https://images.unsplash.com/photo-1511556532299-8f662fc26c06?q=80&w=400&auto=format&fit=crop" 
              alt="Wholesale options display" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-90 group-hover:opacity-75"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-brand-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4">
              <span class="text-brand-light font-accent font-bold text-[10px] tracking-wider uppercase border border-brand-light/45 px-3 py-1.5 rounded-full">Wholesale Supply</span>
            </div>
          </div>

          <!-- Item 6 -->
          <div class="group relative aspect-square rounded-2xl overflow-hidden bg-brand-dark border border-brand-gold/10">
            <img 
              src="https://images.unsplash.com/photo-1505751172876-fa1923c5c528?q=80&w=400&auto=format&fit=crop" 
              alt="Contact lenses stock" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-90 group-hover:opacity-75"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-brand-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4">
              <span class="text-brand-light font-accent font-bold text-[10px] tracking-wider uppercase border border-brand-light/45 px-3 py-1.5 rounded-full">Contact Lenses</span>
            </div>
          </div>

        </div>

      </div>

    </div>

  </div>
</section>
