---
---
<section class="py-20 bg-brand-light relative overflow-hidden" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
      <h2 class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-brand-dark">
        Why Choose <span class="font-normal italic text-brand-gold-dark">Avtar Opticals?</span>
      </h2>
      <p class="font-sans text-brand-dark/70 text-sm sm:text-base leading-relaxed">
        Providing Bhilai with professional care, a welcoming environment, and a massive range of wholesale and retail eyewear options.
      </p>
    </div>

    <!-- Feature Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      
      <!-- Feature Card 1: Friendly Service -->
      <div class="glass-card glass-card-hover p-8 rounded-2xl flex flex-col justify-between h-full space-y-6">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold-dark">
            <!-- SVG Icon: Users / Friendly -->
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="font-display font-semibold text-lg text-brand-dark">Friendly Staff & Owner</h3>
          <p class="text-xs sm:text-sm text-brand-dark/70 leading-relaxed">
            Enjoy a highly welcoming and supportive optical shopping experience. Our friendly staff and dedicated owner are always here to guide you.
          </p>
        </div>
        <div class="text-[10px] font-accent font-bold text-brand-gold-dark tracking-widest uppercase">Welcoming Care</div>
      </div>

      <!-- Feature Card 2: Stylish yet Practical -->
      <div class="glass-card glass-card-hover p-8 rounded-2xl flex flex-col justify-between h-full space-y-6">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold-dark">
            <!-- SVG Icon: Eye / Full Coverage -->
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-display font-semibold text-lg text-brand-dark">Stylish yet Practical</h3>
          <p class="text-xs sm:text-sm text-brand-dark/70 leading-relaxed">
            Get the perfect blend of modern fashion and eye health. Our frames are curated to provide full eye coverage and protection.
          </p>
        </div>
        <div class="text-[10px] font-accent font-bold text-brand-gold-dark tracking-widest uppercase">Full Eye Coverage</div>
      </div>

      <!-- Feature Card 3: Wholesale Frames -->
      <div class="glass-card glass-card-hover p-8 rounded-2xl flex flex-col justify-between h-full space-y-6">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold-dark">
            <!-- SVG Icon: Grid / Wholesale -->
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
            </svg>
          </div>
          <h3 class="font-display font-semibold text-lg text-brand-dark">Wholesale & Retail</h3>
          <p class="text-xs sm:text-sm text-brand-dark/70 leading-relaxed">
            We are primary wholesalers supplying optical stores in Chhattisgarh. Benefit from factory-direct pricing on bulk orders or single retail purchases.
          </p>
        </div>
        <div class="text-[10px] font-accent font-bold text-brand-gold-dark tracking-widest uppercase">Bulk Selection</div>
      </div>

      <!-- Feature Card 4: Brand Contacts -->
      <div class="glass-card glass-card-hover p-8 rounded-2xl flex flex-col justify-between h-full space-y-6">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold-dark">
            <!-- SVG Icon: Shield / Quality -->
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <h3 class="font-display font-semibold text-lg text-brand-dark">Bausch + Lomb Stockist</h3>
          <p class="text-xs sm:text-sm text-brand-dark/70 leading-relaxed">
            We supply leading contact lens products including Bausch + Lomb, providing high vision clarity, breathability, and dry-eye protection.
          </p>
        </div>
        <div class="text-[10px] font-accent font-bold text-brand-gold-dark tracking-widest uppercase">Genuine Brands</div>
      </div>

    </div>
  </div>
</section>
