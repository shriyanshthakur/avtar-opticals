---
---
<section class="relative bg-brand-cream overflow-hidden py-16 sm:py-24 lg:py-32">
  <!-- Dynamic background shapes -->
  <div class="absolute inset-0 z-0 opacity-40">
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-12 w-96 h-96 rounded-full bg-brand-gold/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 translate-y-12 -translate-x-12 w-96 h-96 rounded-full bg-brand-gold/10 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Text Content Area -->
      <div class="lg:col-span-7 flex flex-col justify-center text-left space-y-8 animate-fade-in-up">
        
        <!-- Trust Badge / Business Type -->
        <div class="inline-flex items-center gap-2 w-fit px-3 py-1 bg-brand-gold/10 border border-brand-gold/25 rounded-full">
          <span class="flex h-2 w-2 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-gold opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-gold"></span>
          </span>
          <span class="text-[10px] sm:text-xs font-accent font-bold tracking-wider text-brand-gold-dark uppercase">
            Optical Wholesaler & Retailer 👓
          </span>
        </div>

        <!-- Headline -->
        <div class="space-y-4">
          <h1 class="font-display font-medium text-4xl sm:text-5xl lg:text-6xl tracking-tight text-brand-dark leading-[1.1]">
            Bhilai's Trusted <br />
            <span class="font-normal italic text-brand-gold-dark">Optical Partner</span>
          </h1>
          <p class="font-sans text-brand-dark/70 text-base sm:text-lg max-w-xl leading-relaxed">
            Avtar Opticals provides a wide selection of wholesale frames and contact lenses like Bausch + Lomb in Sector 6. Known for friendly service and stylish yet practical designs that give full coverage for your eyes.
          </p>
        </div>

        <!-- Key Metrics / Selling Points -->
        <div class="grid grid-cols-2 gap-6 py-2 border-t border-b border-brand-gold/15 max-w-md">
          <div class="space-y-1">
            <div class="font-display text-2xl sm:text-3xl font-bold text-brand-dark">Wholesale</div>
            <div class="font-accent text-[11px] sm:text-xs font-bold tracking-widest text-brand-gold-dark uppercase">Frames & Contacts</div>
          </div>
          <div class="space-y-1">
            <div class="font-display text-2xl sm:text-3xl font-bold text-brand-dark">Practical</div>
            <div class="font-accent text-[11px] sm:text-xs font-bold tracking-widest text-brand-gold-dark uppercase">Full Eye Coverage</div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-wrap gap-4 pt-2">
          <a 
            href="#wholesale-inquiries" 
            class="px-8 py-4 bg-brand-dark hover:bg-brand-dark-card text-brand-light font-accent font-bold tracking-wider text-xs uppercase rounded-full border border-brand-dark transition-all duration-300 shadow-lg shadow-brand-dark/15 hover:scale-[1.02] active:scale-[0.98]"
          >
            Wholesale Inquiries
          </a>
          <a 
            href="tel:07987170637" 
            class="px-8 py-4 bg-transparent hover:bg-brand-gold/5 border border-brand-gold/45 text-brand-dark font-accent font-bold tracking-wider text-xs uppercase rounded-full transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
          >
            Call 079871 70637
          </a>
        </div>
      </div>

      <!-- Image Display Area -->
      <div class="lg:col-span-5 relative w-full flex justify-center items-center">
        <!-- Main Image Card Frame -->
        <div class="relative w-full max-w-[400px] lg:max-w-full aspect-[4/5] rounded-[2rem] overflow-hidden border border-brand-gold/20 shadow-2xl animate-scale-in">
          <img 
            src="/assets/images/store-interior.png" 
            alt="Avtar Opticals store interior in Bhilai showcasing quality frames" 
            class="w-full h-full object-cover object-center transition-transform duration-[2000ms] hover:scale-105"
            loading="eager"
          />
          <!-- Decorative Dark Overlay at the bottom -->
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/60 via-transparent to-transparent"></div>
        </div>

        <!-- Overlapping Glassmorphic Badge - 1 (Sunday hours reminder) -->
        <div class="absolute bottom-8 -left-6 sm:-left-10 bg-brand-light/90 backdrop-blur-md border border-brand-gold/20 p-3 sm:p-4 rounded-2xl shadow-xl flex items-center gap-3 animate-pulse-subtle max-w-[220px]">
          <div class="w-8 h-8 rounded-full bg-brand-gold/10 flex items-center justify-center text-brand-gold-dark font-bold text-sm">
            ⏰
          </div>
          <div>
            <div class="text-[10px] font-accent font-bold text-brand-gold-dark uppercase tracking-wider">Sunday Hours</div>
            <div class="text-xs font-bold text-brand-dark">Closes at 9:30 AM</div>
            <a href="#location" class="text-[9px] font-semibold text-brand-gold-dark hover:underline block mt-0.5">Call for store hours</a>
          </div>
        </div>

        <!-- Overlapping Glassmorphic Badge - 2 (Google Ratings) -->
        <div class="absolute top-8 -right-6 sm:-right-8 bg-brand-light/95 backdrop-blur-md border border-brand-gold/20 p-3 sm:p-4 rounded-2xl shadow-xl flex items-center gap-3">
          <div class="text-amber-500 font-bold text-xl">★</div>
          <div>
            <div class="text-[10px] font-accent font-bold text-brand-gold-dark uppercase tracking-wider">Google Rating</div>
            <div class="text-xs font-bold text-brand-dark flex items-center gap-1">
              <span>3.8 Stars</span>
              <span class="text-brand-gray text-[10px] font-medium">(10 reviews)</span>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>
