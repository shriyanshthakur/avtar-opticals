---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import HandmadeAcetate from '../components/HandmadeAcetate.astro';
import SocialProof from '../components/SocialProof.astro';
import LocationHours from '../components/LocationHours.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Avtar Opticals | Trusted Optical Wholesaler & Retailer in Bhilai" 
  description="Bhilai's premier optical wholesaler and retail shop. Stocking a wide selection of frames and contact lenses like Bausch + Lomb. Friendly service and stylish, practical frames providing full eye coverage."
>
  <!-- Hero Showcase Section -->
  <Hero />

  <!-- Trust Value Propositions Banner -->
  <Features />

  <!-- Interactive Category Select Grid -->
  <CategoryGrid />

  <!-- Craftsmanship / Handmade Acetate Highlight Section -->
  <HandmadeAcetate />

  <!-- Social Media & Google Review Proof Section -->
  <SocialProof />

  <!-- Booking Form, Addresses, Maps & Store Hours -->
  <LocationHours />

  <!-- Store Information Footer -->
  <Footer />
</Layout>
